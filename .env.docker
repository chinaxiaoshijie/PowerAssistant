# 管理助手 - Docker 部署环境配置
# Docker 专用，用于生产部署

# ========================================
# 数据库配置
# ========================================
DB_URL=postgresql+asyncpg://postgres:postgres@db:5432/malong_management
DB_ECHO=false

# ========================================
# 飞书配置
# ========================================
# ⚠️ 需要替换为你自己的飞书应用配置
FEISHU_APP_ID=cli_a9b8cf4f41f99bdd
FEISHU_APP_SECRET=SVj3wUYhBygyTlBwBAIBnhbiiY4VoVn5
FEISHU_BASE_URL=https://open.feishu.cn/open-apis
FEISHU_TOKEN_REFRESH_BUFFER_MINUTES=10
FEISHU_RATE_LIMIT_DELAY_MS=100

# ========================================
# 应用配置
# ========================================
APP_NAME=管理助手
APP_VERSION=0.1.0
ENVIRONMENT=production
DEBUG=false

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json

# 同步配置
SYNC_INTERVAL_HOURS=6

# ========================================
# AI 模型配置 - 阿里云 DashScope
# ========================================
DASHSCOPE_API_KEY=sk-4ac26721ba2e4c54ba6e8a777e42e257
DEFAULT_AI_MODEL=qwen-max

# 可选的其他 AI 提供商（用于未来扩展）
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=

# ========================================
# 飞书通知配置
# ========================================
FEISHU_NOTIFICATION_CHAT_ID=
FEISHU_WEBHOOK_URL=
ENABLE_DAILY_NOTIFICATION=false
ENABLE_INTELLIGENCE_ALERTS=false
ALERT_RELEVANCE_THRESHOLD=0.7
