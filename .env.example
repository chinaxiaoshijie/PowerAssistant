# ========================================
# 应用配置
# ========================================
NAME=Malong Management Assistant
VERSION=1.0.0
ENVIRONMENT=production

# ========================================
# 数据库配置
# ========================================
# Docker 环境会自动覆盖为: postgresql+asyncpg://postgres:postgres@db:5432/malong_management
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/malong_management

# 数据库连接池配置（可选）
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# ========================================
# 飞书配置
# ========================================
# 从飞书开放平台获取：https://open.feishu.cn/app/
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxx

# 飞书机器人 Webhook（可选，用于推送通知）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# 飞书 API 基础 URL
FEISHU_API_BASE_URL=https://open.feishu.cn

# API 调用频率限制（可选）
FEISHU_API_RATE_LIMIT=100      # 每分钟最大请求数
FEISHU_API_TIMEOUT=30          # 超时时间（秒）

# ========================================
# AI 引擎配置
# ========================================
# 支持的提供商: deepseek, claude, openai, moonshot 等
AI_MODEL_PROVIDER=deepseek

# 模型名称
AI_MODEL_NAME=deepseek-chat

# API Key（从对应提供商获取）
AI_MODEL_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# API 基础 URL（可选，默认使用提供商默认地址）
# AI_MODEL_BASE_URL=https://api.deepseek.com

# AI 调用配置
AI_MODEL_TEMPERATURE=0.7        # 创造性参数 (0.0-1.0)
AI_MODEL_MAX_TOKENS=4096        # 最大输出长度
AI_MODEL_TIMEOUT=60             # 超时时间（秒）

# ========================================
# Redis 配置（可选，用于缓存和任务队列）
# ========================================
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true

# Redis 连接池配置（可选）
REDIS_MAX_CONNECTIONS=10
REDIS_TIMEOUT=5

# 缓存配置
CACHE_DEFAULT_TTL=3600          # 默认缓存时间（秒）
CACHE_ENABLED=true

# ========================================
# 定时任务配置
# ========================================
# 数据同步间隔（秒）
SYNC_INTERVAL=3600              # 1小时

# 是否启用定时任务
ENABLE_SCHEDULER=true

# 同步任务配置
SYNC_ORG_ENABLED=true           # 同步组织架构
SYNC_TASK_ENABLED=true          # 同步任务数据
SYNC_PROJECT_ENABLED=true       # 同步项目数据
SYNC_OKR_ENABLED=true           # 同步 OKR 数据

# 首次同步延迟（秒）
INITIAL_SYNC_DELAY=60

# ========================================
# 日志配置
# ========================================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=/app/logs/app.log

# 日志格式
LOG_FORMAT=json                 # json 或 text

# 日志轮转
LOG_MAX_BYTES=50000000          # 50MB
LOG_BACKUP_COUNT=10

# ========================================
# 服务器配置
# ========================================
# 服务监听地址
HOST=0.0.0.0
PORT=8000

# Worker 进程数（仅原生部署使用）
WORKERS=4

# 超时配置
REQUEST_TIMEOUT=30              # 请求超时（秒）
KEEP_ALIVE_TIMEOUT=5            # 保持连接超时（秒）

# ========================================
# 安全配置
# ========================================
# CORS 配置（生产环境建议配置具体域名）
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# API 认证（可选）
API_SECRET_KEY=change_this_secret_key_in_production

# JWT 配置（如果使用 JWT 认证）
JWT_SECRET_KEY=change_this_jwt_secret_key_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ========================================
# 性能优化
# ========================================
# 启用响应压缩
ENABLE_GZIP=true

# 启用请求限流
ENABLE_RATE_LIMIT=true
RATE_LIMIT_MAX=100              # 每分钟最大请求数
RATE_LIMIT_WINDOW=60            # 时间窗口（秒）

# ========================================
# 监控配置
# ========================================
# 启用 Prometheus metrics
ENABLE_METRICS=true
METRICS_PATH=/metrics

# 健康检查配置
HEALTH_CHECK_PATH=/api/v1/health
HEALTH_CHECK_TIMEOUT=5

# ========================================
# 其他配置
# ========================================
# 时区
TIMEZONE=Asia/Shanghai

# 语言
LANGUAGE=zh-CN

# 调试模式（生产环境必须为 false）
DEBUG=false

# 应用实例名称（用于区分多个实例）
INSTANCE_NAME=production-01
